# Environment variables template
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to version control

# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Supported providers: openai, anthropic, google, zhipuai, azure, ollama
LLM_PROVIDER=openai

# ============================================================================
# OpenAI Configuration (if LLM_PROVIDER=openai)
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0

# ============================================================================
# Anthropic Configuration (if LLM_PROVIDER=anthropic)
# ============================================================================
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-haiku-20240307
# ANTHROPIC_TEMPERATURE=0

# ============================================================================
# Google Configuration (if LLM_PROVIDER=google)
# ============================================================================
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_MODEL=gemini-pro
# GOOGLE_TEMPERATURE=0

# ============================================================================
# ZhipuAI Configuration (if LLM_PROVIDER=zhipuai)
# ============================================================================
# ZHIPUAI_API_KEY=your_zhipuai_api_key_here
# ZHIPUAI_MODEL=glm-4
# ZHIPUAI_TEMPERATURE=0

# ============================================================================
# Azure OpenAI Configuration (if LLM_PROVIDER=azure)
# ============================================================================
# AZURE_OPENAI_API_KEY=your_azure_api_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-35-turbo
# AZURE_OPENAI_API_VERSION=2024-02-01

# ============================================================================
# Ollama Configuration (if LLM_PROVIDER=ollama)
# ============================================================================
# OLLAMA_MODEL=llama2
# OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# Retrieval Configuration
# ============================================================================
RETRIEVAL_K=3
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ============================================================================
# Directory Configuration
# ============================================================================
DOCUMENTS_DIR=./documents
CHROMA_DIR=./chroma_db

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_DIR=./logs
LOG_LEVEL=INFO

# ============================================================================
# Retry Configuration
# ============================================================================
MAX_RETRIES=3
RETRY_DELAY=1.0
RETRY_BACKOFF=2.0
